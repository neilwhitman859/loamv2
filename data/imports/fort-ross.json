      "subzone": "Fort Ross-Seaview AVA, Sonoma Coast",
      "vineyard_size_acres": 51,
      "num_blocks": 33,
      "elevation_feet_low": 1200,
      "elevation_feet_high": 1700,
      "distance_to_ocean_miles": "<1",
      "philosophy": "Gentle winemaking with minimal intervention. Effort placed in farming. Over thirty vineyard blocks farmed individually. Night harvest, native fermentation, French oak aging.",
      "winemaking": "Hand-harvested at night in small 2-gallon trays, hand-sorted, destemmed, cold-soaked several days, open-top fermenters (5 and 10-ton tanks), manual punch-down, native yeast fermentation, French oak aging. Many wines bottled unfined and unfiltered.",
      "grape_varieties_planted": ["Pinot Noir", "Chardonnay", "Pinotage", "Chenin Blanc"],
      "pinot_noir_clones": ["Calera", "Pommard", "Swan", "Dijon 115", "Vosne-Romanée field selection"],
      "chardonnay_clones": ["Hyde field selection", "Old Wente field selection"],
      "pinotage_clones": ["MM1", "MM3 (proprietary, imported from South Africa via UC Davis Foundation Plant Services)"],
      "pinotage_origin": "First private growers to import Pinotage bud wood from South Africa through UC Davis Foundation Plant Services",
      "second_label": "Sea Slopes",
      "historical_note": "Vineyard located near the historic Fort Ross, where the first grapevines in Sonoma County were planted in 1817 by Russian settlers."
    },
    "winemakers": [
      {
        "name": "Jeff Pisoni",
        "role": "head",
        "country": "United States",
        "start_year": 2009,
        "metadata": {
          "education": "California State University, Fresno (Enology)",
          "family": "Pisoni family of Santa Lucia Highlands"
        }
      }
    ]
  },
  "_notes": {
    "wine_naming_evolution": "Early vintages (2000-~2015) used 'Reserve' tier and 'Symposium' as cuvée names. The 'FRV' designation appeared around 2013-2017 for estate Pinot Noir and Chardonnay. By ~2018+ the estate Pinot became simply 'Pinot Noir' and the single-block wines (Top of Land, Stagecoach Road, The Terraces) became the top tier. 'Bicentennial Commemorative Bottling' wines began in 2010 to commemorate the 1812-2012 bicentennial of the Russian Settlement of Fort Ross.",
    "sea_slopes_history": "Sea Slopes originated as a limited-production barrel blend in 2004. Due to high demand, it was established as a dedicated brand in 2015 for a 'softer, more approachable, fruit-forward wine.' Sea Slopes Chardonnay was introduced with the 2018 vintage. Appellation is Sonoma Coast (not Fort Ross-Seaview).",
    "model_as_separate_producer": "Sea Slopes should be modeled as a separate producer with parent_producer_id pointing to Fort Ross Vineyard & Winery."
  },
