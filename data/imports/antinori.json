    "metadata": {
      "owners": "Antinori family (Albiera, Allegra, and Alessia Antinori — 26th generation)",
      "headquarters": "Florence, Tuscany",
      "annual_production_bottles": 20000000,
      "num_labels": 150,
      "philosophy": "Innovation within tradition. Pioneers of the Super Tuscan movement in the 1970s, blending international varieties with native Sangiovese. Quality-driven across all price tiers.",
      "estates_tuscany": [
        "Tenuta Tignanello (Chianti Classico — 319 ha, 165 ha vines)",
        "Antinori nel Chianti Classico (Chianti Classico — winery/cellar)",
        "Tenuta Guado al Tasso (Bolgheri — 900 ha, 300 ha vines)",
        "Pian delle Vigne (Montalcino — 184 ha, 65 ha vines)"
      ],
      "estates_umbria": [
        "Castello della Sala (Orvieto — 500 ha, 170 ha vines)"
      ],
      "historical_note": "One of the oldest wine families in the world. Giovanni di Piero Antinori enrolled in the Florentine Vintners' Guild in 1385. Marchese Piero Antinori led the Super Tuscan revolution in the 1970s with the creation of Tignanello (1971) and Solaia (1978)."
    },
    "winemakers": [
      {
        "name": "Renzo Cotarella",
        "role": "head",
        "country": "Italy",
        "start_year": 1979,
        "metadata": {
          "title": "CEO and Chief Enologist",
          "note": "Joined in 1979 as winemaker at Castello della Sala. Succeeded Giacomo Tachis as head winemaker for entire company in 1992. Promoted to CEO in 2005. Created Cervaro della Sala (first vintage 1985)."
        }
      }
    ]
  },
  "_notes": {
    "scope": "Core Tuscan and Umbrian portfolio — the 25 most important wines. Excludes international estates (Antica Napa Valley, Atlas Peak, Stag's Leap, Col Solare, Haras de Pirque, etc.), Puglia (Tormaresca), Lombardy (Montenisa), Piedmont (Prunotto — separate brand), and minor/value labels.",
    "score_sourcing": "Scores from Wine Advocate (Monica Larner), James Suckling, Wine Spectator, Vinous (Antonio Galloni), Decanter, Wine Enthusiast, Jeb Dunnuck. Sourced from wine-searcher.com aggregation, retailer pages, and critic review announcements. All scores verified across multiple sources where possible.",
    "blend_note": "Antinori adjusts blend percentages slightly each vintage. Where vintage-specific data was found, those percentages are used. Otherwise, the standard/typical blend is listed.",
    "appellations": "IGT Toscana is used for Super Tuscan wines (Tignanello, Solaia). These are designated IGT rather than DOCG because they use non-traditional grape varieties. The DB appellation field should be null or mapped to a generic Toscana IGT if one exists."
  },
